# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx_or_anon_key_xxx

# Server-side only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Optional: when deploying to a non-Vercel environment, set the public site URL
# so server components can call their own API routes via absolute URL.
# NEXT_PUBLIC_SITE_URL=https://your-deployment.example.com

# OpenCode (https://opencode.ai) — the brain behind the ephemeral agents.
# Get your API key from the OpenCode dashboard.
OPENCODE_API_KEY=
# Optional: override the API base URL (default: https://api.opencode.ai)
# OPENCODE_BASE_URL=https://api.opencode.ai
# Optional: default model (default: anthropic/claude-sonnet-4.5)
# OPENCODE_DEFAULT_MODEL=anthropic/claude-sonnet-4.5

# Telegram bridge (optional). When set, messages sent from the board are
# forwarded to Clawdia via Telegram, and messages from Clawdia appear in the
# board chat in real time.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_WEBHOOK_SECRET=random_string_used_to_verify_webhook
CLAWDIA_CHAT_ID=123456789

# Budget guard (USD/day). When the day's agent spend reaches this value,
# new agent runs are paused with status='paused_budget'.
DAILY_BUDGET_USD=1.00
